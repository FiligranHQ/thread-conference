# Copy this file to .env.local and fill in your Sanity project credentials.
# Get these from https://www.sanity.io/manage → your project.

# Required: your Sanity project ID (e.g. abc12def)
SANITY_STUDIO_PROJECT_ID=

# The dataset to use. Use "production" unless you have a separate staging dataset.
SANITY_STUDIO_DATASET=production
